# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Mapbox (carte interactive) ────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── AWS Rekognition (comparaison de visages pour vérif. identité) ─────────────
# Créer un compte AWS → IAM → utilisateur avec politique AmazonRekognitionReadOnlyAccess
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── Sightengine (détection de photos IA / générées) ───────────────────────────
# Plan gratuit : 500 requêtes/mois sur sightengine.com
NEXT_PUBLIC_SIGHTENGINE_USER=your-api-user
SIGHTENGINE_SECRET=your-api-secret

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DateRéunion
